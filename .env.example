# Internal Admin System

# Database
# 从 ownServer/.env 复制 DB_HOST、DB_USER、DB_PASSWORD。
# DB_NAME 改成新后台系统的数据库名。
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=internal_admin_system

# JWT
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Password hashing
BCRYPT_ROUNDS=12

# WeCom / 企业微信机器人
# 从 ownServer/.env 复制 APP_MODE、WECHAT_WEBHOOK_* 配置。
APP_MODE=debug
WECHAT_WEBHOOK_URL_DEBUG=
WECHAT_WEBHOOK_KEY_DEBUG=
WECHAT_WEBHOOK_URL_PROD=
WECHAT_WEBHOOK_KEY_PROD=
WECHAT_WEBHOOK_URL_FLOW_PROD=
WECHAT_WEBHOOK_KEY_FLOW_PROD=
