# Internal Admin System production environment

APP_ENV=prod
SECRET_KEY=replace-with-a-long-random-secret
DEFAULT_OPERATOR_ID=1
BACKEND_HOST=127.0.0.1
BACKEND_PORT=5000
BACKEND_DEBUG=0
CORS_ORIGINS=https://your-admin-domain.example.com

MYSQL_HOST=prod-mysql-host
MYSQL_PORT=3306
MYSQL_USER=internal_admin_user
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=internal_admin_system

VITE_API_BASE_URL=https://your-api-domain.example.com

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
BCRYPT_ROUNDS=12

APP_MODE=prod
WECHAT_WEBHOOK_URL_DEBUG=
WECHAT_WEBHOOK_KEY_DEBUG=
WECHAT_WEBHOOK_URL_PROD=
WECHAT_WEBHOOK_KEY_PROD=
WECHAT_WEBHOOK_URL_FLOW_PROD=
WECHAT_WEBHOOK_KEY_FLOW_PROD=
